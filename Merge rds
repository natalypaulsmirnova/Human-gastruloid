library(Seurat)

# Folder
folder <- "Z:/Human Gastruloid scRNA-seq/New Annotations RDS"

# Load objects
day2 <- readRDS(file.path(folder, "Day2_annotated.rds"))
day3 <- readRDS(file.path(folder, "Day3_annotated.rds"))
day4 <- readRDS(file.path(folder, "Day4_annotated.rds"))
day5 <- readRDS(file.path(folder, "Day5_annotated.rds"))

# Add day metadata
day2$Day <- "Day2"
day3$Day <- "Day3"
day4$Day <- "Day4"
day5$Day <- "Day5"

# Merge objects
combined <- merge(
  x = day2,
  y = list(day3, day4, day5),
  add.cell.ids = c("Day2", "Day3", "Day4", "Day5"),
  project = "Human_Gastruloid_AllDays"
)

# Check
print(combined)
print(table(combined$Day))

# Save merged object
saveRDS(
  combined,
  file = file.path(folder, "Human_Gastruloid_AllDays_annotated.rds")
)
